# ============================================
# 消息渠道配置 — 飞书 / Lark（v0.14.0+ 可用）
# ============================================
# 配置文件：~/.clawhermes/channels/feishu.yaml
# 敏感值：存放在 .env（FEISHU_APP_ID / FEISHU_APP_SECRET 等）
# 引用语法：${FEISHU_APP_ID} → 从环境变量注入
# ============================================

channel_type: feishu
enabled: true                    # false 则不启动飞书适配器

# ── 凭证（从 .env 注入）─────────────────────────────────────────
app_id: "${FEISHU_APP_ID}"
app_secret: "${FEISHU_APP_SECRET}"

# ── 安全（从 .env 注入）─────────────────────────────────────────
verification_token: "${FEISHU_VERIFICATION_TOKEN}"
encrypt_key: "${FEISHU_ENCRYPT_KEY}"

# ── 域名 / 连接模式 ──────────────────────────────────────────────
domain: feishu                   # feishu（国内）| lark（国际版）
connection_mode: websocket       # websocket（长连接，推荐）| webhook（HTTP 回调）

# ── Bot 身份 ─────────────────────────────────────────────────────
bot_open_id: "${FEISHU_BOT_OPEN_ID}"     # Bot 的 open_id，从 .env 注入
bot_user_id: "${FEISHU_BOT_USER_ID}"     # Bot 的 user_id（需 contact 权限），从 .env 注入
bot_name: ""                              # Bot 显示名称（可选，不配则用 API 获取）

# ── 群聊权限 ─────────────────────────────────────────────────────
# 策略: open | allowlist | blacklist | admin_only | disabled
group_policy: allowlist
allowed_group_users:             # 白名单/黑名单 open_id 列表
  - ""
admins:                          # 管理员 open_id（不受群聊策略限制）
  - ""
allow_bots: none                 # none（忽略所有 Bot）| mentions（被 @时响应）| all（响应所有 Bot）
require_mention: true            # 群聊中是否需要 @Bot 才响应

# ── Webhook 模式（connection_mode: webhook 时生效）────────────────
webhook_host: "0.0.0.0"
webhook_port: 8080
webhook_path: "/feishu/webhook"

# ── WebSocket 重连 / 心跳 ────────────────────────────────────────
ws_reconnect_nonce: 30           # 重连随机抖动上限（秒）
ws_reconnect_interval: 120       # 重连基础间隔（秒）
ws_ping_interval: null           # 心跳间隔（null = SDK 默认）
ws_ping_timeout: null            # 心跳超时（null = SDK 默认）

# ── 高级 ─────────────────────────────────────────────────────────
log_level: 20                    # 20=INFO, 10=DEBUG
max_retries: 3                   # API 调用最大重试次数
retry_delay: 1.0                 # 重试基础延迟（秒，指数退避）
dedup_cache_size: 1024           # 消息去重 LRU 容量
reactions_enabled: true          # WS 模式下显示"正在输入"状态
