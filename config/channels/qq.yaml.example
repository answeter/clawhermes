# ============================================
# 消息渠道配置 — QQ Bot（v0.15.0+ 可用）
# ============================================
# 配置文件：~/.clawhermes/channels/qq.yaml
# 敏感值：存放在 .env（QQ_APP_ID / QQ_TOKEN / QQ_SECRET）
# 引用语法：${QQ_APP_ID} → 从环境变量注入
# ============================================

channel_type: qq
enabled: true                    # false 则不启动 QQ 适配器

# ── 凭证（从 .env 注入）─────────────────────────────────────────
app_id: "${QQ_APP_ID}"           # BotAppID (uint64 string)
token: "${QQ_TOKEN}"             # BotToken
secret: "${QQ_SECRET}"           # BotSecret（签名校验，可选）

# ── 环境 ─────────────────────────────────────────────────────────
sandbox: true                    # true = 沙箱环境, false = 正式环境

# ── 连接 ─────────────────────────────────────────────────────────
auto_reconnect: true             # WebSocket 断线自动重连
heartbeat_interval: 40000        # 心跳间隔（毫秒，默认 40s）

# ── 高级 ─────────────────────────────────────────────────────────
max_retries: 3                   # API 调用最大重试次数
retry_delay: 1.0                 # 重试基础延迟（秒，指数退避）
