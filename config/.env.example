# ============================================
# ClawHermes 环境变量（.env）
# ============================================
# 复制为 .env 后填入真实值
# 非敏感操作配置请放在对应的 YAML 文件中
# 详见 docs/env-reference.md 和 config/README.md
# ============================================

# --- LLM API Key（至少配一个）---
DEEPSEEK_API_KEY=sk-xxx
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=

# --- 模型选择（可选，默认 deepseek/deepseek-chat）---
CH_DEFAULT_MODEL=deepseek/deepseek-chat

# --- Gateway 服务（可选）---
# CH_GATEWAY_HOST=127.0.0.1
# CH_GATEWAY_PORT=18789
# CH_GW_API_KEY=sk-xxx              # Gateway 自动初始化用（cli start 自动设置）
# CH_GW_MODEL=deepseek/deepseek-chat

# --- 工具集级别（可选，默认 standard）---
# minimal=5个 | standard=9个 | full=35个
CH_TOOLS_PROFILE=standard

# --- 数据目录（可选，默认 ~/.clawhermes）---
# CH_DATA_DIR=~/.clawhermes


# ============================================
# 渠道 — 敏感值（仅存放密钥/Token）
# 非敏感操作配置放在 config/channels/<name>.yaml.example 中
# ============================================

# === 飞书（需 pip install -e ./clawhermes-lark）===
# FEISHU_APP_ID=cli_xxx
# FEISHU_APP_SECRET=xxx
# FEISHU_VERIFICATION_TOKEN=xxx
# FEISHU_ENCRYPT_KEY=xxx
# FEISHU_BOT_OPEN_ID=ou_xxx          # 可选，Bot 自身 open_id
# FEISHU_BOT_USER_ID=u_xxx           # 可选，Bot 自身 user_id

# === 微信（需 pip install -e ./clawhermes-weixin）===
# WECHAT_SESSION_KEY=xxx             # 个人微信 iLink Bot session_key
# WECOM_BOT_KEY=xxx                  # 企业微信机器人 Webhook Key
